{
  "name": "dashboard-root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 startOrRestart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop \"Dashboard Backend\"",
    "pm2:status": "pm2 describe \"Dashboard Backend\"",
    "pm2:logs": "pm2 logs \"Dashboard Backend\" --lines 120",
    "pm2:logs:once": "pm2 logs \"Dashboard Backend\" --lines 120 --nostream",
    "pm2:monit": "pm2 monit"
  }
}
